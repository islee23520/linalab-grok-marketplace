{
  "description": "Refresh CLIProxyAPI model metadata when a Grok session starts.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/dist/cli.mjs\" sync --hook",
            "timeout": 20,
            "description": "Sync CLIProxyAPI model metadata",
            "statusMessage": "Checking CLIProxyAPI models"
          }
        ]
      }
    ]
  }
}
